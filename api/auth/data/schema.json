{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Admin Seed Data",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "admins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "id",
          "name",
          "email"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "$schema",
    "admins"
  ],
  "additionalProperties": false
}